<mvc:View xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:l="sap.ui.layout" xmlns:grid="sap.ui.layout.cssgrid" xmlns:f="sap.ui.layout.form" xmlns:core="sap.ui.core" controllerName="com.sysco.wm.palletisationui.controller.LabelPrint">
    <Page title="{i18n>title}" showHeader="false" showFooter="false">
        <HBox width="100vw" fitContainer="true" visible="true" class="twoRemPadding">
            <VBox width="70%" height="auto" class="borderRight" fitContainer="true">
                <HBox>
                        <items>
                            <Title id="titleRoute1" text="" class="sapUiTinyMargin"/>
                            <ObjectStatus state="Success" text="{i18n>open}" class="sapUiTinyMargin"/>
                            <Label id="LabelRoute1" text="" class="sapUiTinyMargin"/>
                        </items>
                    </HBox>
                    <Button text="{i18n>skip}" class="blackButton roundCorner" visible="false"/>
                <Table id="cageList1" items="{                                 path: 'flattened>/visibleResults'                                 }" inset="false" mode="None">
                   <columns>
                            <Column>
                                <Text text="{i18n>cage_id}" wrapping="false"/>
                            </Column>
                            <Column>
                                <Text text="{i18n>material}" wrapping="false"/>
                            </Column>
                            <Column>
                                <Text text="{i18n>total_quantity}" wrapping="false"/>
                            </Column>
                            <Column >
                                <Text text="{i18n>unit_code}" wrapping="false"/>
                            </Column>
                            <Column >
                                <Text text="{i18n>position}" wrapping="false"/>
                            </Column>
                            <Column>
                                <Text text="{i18n>status}"/>
                            </Column>
                        </columns>

                        <items>
                            <ColumnListItem vAlign="Middle">
                                <cells>
                                    <Text text="{flattened>CageID}"/>
                                    <Text text="{flattened>Material}"/>
                                    <Text text="{flattened>TotalQuantity}"/>
                                    <Text text="{flattened>Uom_UnitCode}"/>
                                    <Text text="{flattened>PositionInCage}"/>
                                    <ObjectStatus state="{flattened>Status}" icon="sap-icon://circle-task-2"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                </Table>
                <HBox justifyContent="Center">
                    <!-- Up Arrow -->
                    <Button id="btnUp1" icon="sap-icon://navigation-up-arrow" class="roundCorner borderless upArrowBlack largeIcon" type="Transparent" press=".onShowLess" visible="false"/>
                    <!-- hidden initially -->

                    <!-- Down Arrow -->
                    <Button id="btnDown1" icon="sap-icon://navigation-down-arrow" class="roundCorner borderless downArrowBlack largeIcon" type="Transparent" press=".onShowMore"/>
                </HBox>
            </VBox>
            <VBox width="30%" height="auto" alignItems="Center" alignContent="Center" justifyContent="Center" class="borderLeft customPadding" visible="true" fitContainer="true">
                <VBox alignItems="Start">
                    <items>
                        <Button text="{i18n>print}" class="blackButton largeWidth roundCorner mediumButton customHeightLabelPrint" press="onPrint"/>
                        <Button text="{i18n>next_pallet}" class="blackButton largeWidth roundCorner mediumButton customHeightLabelPrint" press="nextPallet"/>
                        <Button text="{i18n>next_route}" class="blackButton largeWidth roundCorner mediumButton customHeightLabelPrint" enabled="false"/>
                    </items>
                </VBox>
            </VBox>
        </HBox>
    </Page>
</mvc:View>