<mvc:View xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form" xmlns:core="sap.ui.core" controllerName="com.sysco.wm.palletisationui.controller.StationList">
    <Page title="{i18n>title}" showHeader="false">
        <HBox id="hbStationList" width="100vw" fitContainer="true" visible="true">
            <VBox id="stationListButtonsBox"  width="50vw" height="100%" alignItems="Center" alignContent="Center" justifyContent="Center" class="borderRight" fitContainer="true">
            </VBox>
            <VBox width="50vw" height="100%" alignItems="Center" alignContent="Center" justifyContent="Center" class="borderLeft" fitContainer="true">
                <VBox alignItems="Start" height="80%">
                    <items>
                        <Button text="{i18n>open}" id="btnOpen" class="blackButton largeWidth roundCorner largeButton customHeight sapUiTinyMargin" press="onOpenPress" enabled="{= ${selectedRecord>/Status_ID} === 'CLOSE'  }" visible="true"/>
                        <Button text="{i18n>close}" id="btnClose" class="blackButton largeWidth roundCorner largeButton customHeight sapUiTinyMargin" press="onOpenPress" enabled="{= ${selectedRecord>/Status_ID} === 'OPEN'  }" visible="true"/>
                    </items>
                </VBox>
            </VBox>
        </HBox> 
    </Page>
</mvc:View>